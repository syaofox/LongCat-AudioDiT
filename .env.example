# 用户 UID/GID（与宿主机一致，避免权限问题）
PUID=1000
PGID=1000

# GitHub 加速代理前缀（留空则直连）
# 中国大陆推荐: https://ghfast.top
GH_PROXY=https://ghfast.top

# apt 包镜像地址（留空则使用官方源）
# 中国大陆推荐: https://mirrors.aliyun.com
APT_MIRROR=https://mirrors.aliyun.com

# PyPI 镜像地址（留空则使用官方源）
# 中国大陆推荐: https://pypi.tuna.tsinghua.edu.cn/simple
PIP_MIRROR=https://pypi.tuna.tsinghua.edu.cn/simple

